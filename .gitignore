<html lang="id">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>EduGuesser - Belajar Sambil Menjelajah</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <!-- Leaflet CSS untuk Peta -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:wght@400;600;800&display=swap');
        
        body {
            font-family: 'Plus Jakarta Sans', sans-serif;
            background-color: #f0f4f8;
        }

        #map {
            height: 400px;
            width: 100%;
            border-radius: 12px;
            cursor: crosshair;
            z-index: 10;
        }

        .custom-shadow {
            box-shadow: 0 10px 25px -5px rgba(0, 0, 0, 0.1), 0 8px 10px -6px rgba(0, 0, 0, 0.1);
        }

        .correct-line {
            stroke: #22c55e;
            stroke-dasharray: 8;
            animation: dash 20s linear infinite;
        }

        @keyframes dash {
            to { stroke-dashoffset: 1000; }
        }
    </style>
</head>
<body class="bg-slate-50 min-h-screen">

    <!-- Menu Utama -->
    <div id="start-screen" class="fixed inset-0 z-50 flex items-center justify-center bg-indigo-900 text-white p-4">
        <div class="text-center max-w-md">
            <h1 class="text-5xl font-extrabold mb-4">EduGuesser 🌍</h1>
            <p class="text-indigo-200 mb-8">Uji pengetahuan mata pelajaranmu dengan menebak lokasi di peta dunia!</p>
            
            <div class="grid grid-cols-1 gap-4">
                <button onclick="startGame('sejarah')" class="bg-orange-500 hover:bg-orange-600 p-4 rounded-xl font-bold transition-all transform hover:scale-105">
                    📜 Sejarah Dunia new toy
                </button>
                <button onclick="startGame('geografi')" class="bg-blue-500 hover:bg-blue-600 p-4 rounded-xl font-bold transition-all transform hover:scale-105">
                    🏔️ Geografi Alamdannewtoy m
                </button>
                <button onclick="startGame('biologi')" class="bg-green-500 hover:bg-green-600 p-4 rounded-xl font-bold transition-all transform hover:scale-105">
                    🌿 Biologi & Ekosistem & new mapel
                </button>
            </div>
        </div>
    </div>

    <!-- Interface Game -->
    <div id="game-ui" class="hidden container mx-auto p-4 max-w-4xl">
        <div class="flex justify-between items-center mb-4 bg-white p-4 rounded-2xl shadow-sm">
            <div>
                <span class="text-slate-500 text-sm block">Mata Pelajaran</span>
                <span id="current-subject" class="font-bold text-indigo-600 uppercase">---</span>
            </div>
            <div class="text-center">
                <span class="text-slate-500 text-sm block">Skor Total</span>
                <span id="total-score" class="font-bold text-2xl">0</span>
            </div>
            <div class="text-right">
                <span class="text-slate-500 text-sm block">Pertanyaan</span>
                <span id="question-count" class="font-bold">1 / 5</span>
            </div>
        </div>

        <div class="bg-white p-6 rounded-3xl custom-shadow mb-6">
            <h2 id="question-text" class="text-xl md:text-2xl font-semibold text-slate-800 text-center mb-4">
                Memuat pertanyaan...
            </h2>
            
            <!-- Area Peta -->
            <div id="map"></div>
            
            <div class="mt-6 flex justify-center">
                <button id="guess-btn" disabled onclick="submitGuess()" class="bg-indigo-600 disabled:bg-slate-300 text-white px-10 py-3 rounded-full font-bold text-lg transition-all shadow-lg hover:bg-indigo-700">
                    TEBAK LOKASI!
                </button>
                <button id="next-btn" onclick="nextQuestion()" class="hidden bg-green-600 text-white px-10 py-3 rounded-full font-bold text-lg transition-all shadow-lg hover:bg-green-700">
                    LANJUT
                </button>
            </div>
        </div>
    </div>

    <!-- Modal Hasil -->
    <div id="result-modal" class="hidden fixed inset-0 z-[100] bg-black/60 flex items-center justify-center p-4">
        <div class="bg-white p-8 rounded-3xl max-w-sm w-full text-center">
            <div id="result-icon" class="text-6xl mb-4">👅</div>
            <h3 class="text-2xl font-bold mb-2" id="result-title">Hebat!</h3>
            <p id="result-distance" class="text-slate-600 mb-1">Jarak: 0 km</p>
            <p id="result-points" class="text-indigo-600 font-bold text-xl mb-6">+0 Poin</p>
            <button onclick="closeModal()" class="w-full bg-slate-900 text-white py-3 rounded-xl font-bold">Lanjut</button>
        </div>
    </div>

    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
        const questions = {
            sejarah: [
                { q: "Di manakah letak rumah abu", lat: -6.488462, lng: 106.885044 },
                { q: "Lokasi Candi Borobudur, monumen Budha terbesar di dunia.", lat: -7.6079, lng: 110.2038 },
                { q: "Di kota manakah tembok besar Berlin pernah membagi dua ideologi dunia?", lat: 52.5163, lng: 13.3777 },
                { q: "Tempat berdirinya Menara Pisa yang miring.", lat: 43.7230, lng: 10.3966 },
                { q: "Kota kuno Machu Picchu peninggalan suku Inka berada di negara mana?", lat: -13.1631, lng: -72.5450 }
            ],
            geografi: [
                { q: "Tempat tertinggi di permukaan bumi, puncak Gunung Everest.", lat: 27.9881, lng: 86.9250 },
                { q: "Di mana lokasi air terjun terbesar di dunia berdasarkan volume, Air Terjun Victoria?", lat: -17.9243, lng: 25.8572 },
                { q: "Lokasi Palung Mariana, titik terdalam di samudra.", lat: 11.3493, lng: 142.1996 },
                { q: "Hutan hujan Amazon yang sering disebut 'Paru-paru Dunia' berpusat di negara?", lat: -3.4653, lng: -62.2159 },
                { q: "Di mana letak Gurun Sahara yang merupakan gurun panas terluas?", lat: 23.4162, lng: 25.6627 }
            ],
            biologi: [
                { q: "Kepulauan Galapagos, tempat Charles Darwin melakukan observasi evolusi.", lat: -0.8293, lng: -90.9821 },
                { q: "Great Barrier Reef, ekosistem terumbu karang terbesar di dunia.", lat: -18.2871, lng: 147.6992 },
                { q: "Lokasi asli habitat Komodo, kadal terbesar di dunia.", lat: -8.5891, lng: 119.4442 },
                { q: "Taman Nasional Serengeti, tempat migrasi besar mamalia darat.", lat: -2.3333, lng: 34.8333 },
                { q: "Habitat asli Panda Besar di pegunungan China.", lat: 30.7441, lng: 103.1111 }
            ]
        };

        let currentData = [];
        let currentIndex = 0;
        let totalScore = 0;
        let map, playerMarker, trueMarker, polyline;
        let selectedCoords = null;

        function initMap() {
            map = L.map('map', {
                center: [20, 0],
                zoom: 2,
                minZoom: 2,
                maxBounds: [[-90,-180], [90,180]]
            });

            L.tileLayer('https://{s}.basemaps.cartocdn.com/light_all/{z}/{x}/{y}{r}.png', {
                attribution: '&copy; OpenStreetMap'
            }).addTo(map);

            map.on('click', function(e) {
                if (polyline) return; // Kunci jika sudah menebak

                selectedCoords = e.latlng;
                
                if (playerMarker) {
                    playerMarker.setLatLng(selectedCoords);
                } else {
                    playerMarker = L.marker(selectedCoords).addTo(map);
                }
                
                document.getElementById('guess-btn').disabled = false;
            });
        }

        function startGame(subject) {
            document.getElementById('start-screen').classList.add('hidden');
            document.getElementById('game-ui').classList.remove('hidden');
            document.getElementById('current-subject').innerText = subject;
            
            currentData = [...questions[subject]].sort(() => Math.random() - 0.5);
            currentIndex = 0;
            totalScore = 0;
            
            if (!map) initMap();
            loadQuestion();
        }

        function loadQuestion() {
            const q = currentData[currentIndex];
            document.getElementById('question-text').innerText = q.q;
            document.getElementById('question-count').innerText = `${currentIndex + 1} / ${currentData.length}`;
            
            // Reset UI
            document.getElementById('guess-btn').classList.remove('hidden');
            document.getElementById('guess-btn').disabled = true;
            document.getElementById('next-btn').classList.add('hidden');
            
            if (playerMarker) { map.removeLayer(playerMarker); playerMarker = null; }
            if (trueMarker) { map.removeLayer(trueMarker); trueMarker = null; }
            if (polyline) { map.removeLayer(polyline); polyline = null; }
            
            selectedCoords = null;
            map.setView([20, 0], 2);
        }

        function submitGuess() {
            const trueLoc = currentData[currentIndex];
            const dist = getDistance(selectedCoords.lat, selectedCoords.lng, trueLoc.lat, trueLoc.lng);
            
            // Hitung skor (skala 0 - 5000)
            let points = Math.max(0, Math.round(5000 * Math.exp(-dist / 2000)));
            totalScore += points;
            document.getElementById('total-score').innerText = totalScore;

            // Tampilkan Jawaban Benar
            trueMarker = L.marker([trueLoc.lat, trueLoc.lng], {
                icon: L.divIcon({
                    html: '📍',
                    className: 'text-3xl',
                    iconSize: [30, 30]
                })
            }).addTo(map);

            polyline = L.polyline([selectedCoords, [trueLoc.lat, trueLoc.lng]], {
                color: '#6366f1',
                weight: 3,
                dashArray: '10, 10'
            }).addTo(map);

            // Zoom out untuk melihat keduanya
            const group = new L.featureGroup([playerMarker, trueMarker]);
            map.fitBounds(group.getBounds().pad(0.2));

            // Modal Hasil
            document.getElementById('result-distance').innerText = `Jarak: ${Math.round(dist)} km`;
            document.getElementById('result-points').innerText = `+${points} Poin`;
            document.getElementById('result-modal').classList.remove('hidden');
            
            document.getElementById('guess-btn').classList.add('hidden');
            document.getElementById('next-btn').classList.remove('hidden');
        }

        function getDistance(lat1, lon1, lat2, lon2) {
            const R = 6371; // Radius bumi dalam km
            const dLat = (lat2 - lat1) * Math.PI / 180;
            const dLon = (lon2 - lon1) * Math.PI / 180;
            const a = Math.sin(dLat/2) * Math.sin(dLat/2) +
                      Math.cos(lat1 * Math.PI / 180) * Math.cos(lat2 * Math.PI / 180) * Math.sin(dLon/2) * Math.sin(dLon/2);
            const c = 2 * Math.atan2(Math.sqrt(a), Math.sqrt(1-a));
            return R * c;
        }

        function closeModal() {
            document.getElementById('result-modal').classList.add('hidden');
        }

        function nextQuestion() {
            currentIndex++;
            if (currentIndex < currentData.length) {
                loadQuestion();
            } else {
                alert(`Game Selesai! Skor akhirmu: ${totalScore}`);
                location.reload();
            }
        }
    </script>
</body>
</html>


